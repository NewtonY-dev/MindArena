# ===========================================
# MindArena Backend Configuration
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=mindarena
DB_PORT=3306
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_at_least_32_characters_long
JWT_EXPIRE=7d

# Security Configuration
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=info

# File Upload (for future features)
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Email Configuration (for future features)
EMAIL_FROM=noreply@mindarena.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cache Configuration
CACHE_TTL=3600

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# AI Grading Configuration
# Set to 'true' to use AI-generated expected answers instead of stored answers
# This generates answers from the question text using Gemini, then evaluates student answers
USE_AI_GENERATED_EXPECTED=false

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_ANALYTICS=false